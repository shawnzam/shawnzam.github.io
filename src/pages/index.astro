<script>
  // History fact for today
  async function showTodayHistoryFact() {
    try {
      const response = await fetch('/history.json');
      const historyOfComputing = await response.json();
      const today = new Date();
      const monthNames = ["January","February","March","April","May","June","July","August","September","October","November","December"];
      const month = monthNames[today.getMonth()];
      const day = today.getDate();
      const todayStr = `${month} ${day}`;
      const fact = historyOfComputing.find((f: {date: string; event: string}) => f.date === todayStr);
      const dateEl = document.getElementById('history-date');
      const factEl = document.getElementById('history-fact');
      if (dateEl) dateEl.textContent = `| ${todayStr}`;
      if (factEl) {
        if (fact) {
          factEl.textContent = fact.event;
        } else {
          factEl.textContent = 'No computing history event found for today.';
        }
      }
    } catch (e) {
      const factEl = document.getElementById('history-fact');
      if (factEl) factEl.textContent = 'Unable to load history fact.';
    }
  }
  showTodayHistoryFact();
</script>
