---
// Pull-down easter egg: overscrolling / pulling down at the very top of
// the page reveals ONE random vintage VHS cassette spine — rendered at
// true spine proportions (~188×25mm ≈ 7.5:1) with subtle, randomized
// aging (grain, fade, tilt, occasional stickers/scuffs). The tape data
// is abstracted from real products; colors/grades sourced from VHS
// archives + brand references. Pushes page content down, holds, retracts.
---

<div id="vhs-stage" class="vhs-stage" aria-hidden="true">
  <div class="vhs-stage__inner"></div>
</div>

<style is:global>
  .vhs-stage {
    height: 0;
    overflow: hidden;
    transition: height 0.55s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .vhs-stage.reveal {
    border-bottom: 1px solid var(--line);
  }
  .vhs-stage__inner {
    display: flex;
    justify-content: center;
    padding: 30px 16px 34px;
  }

  /* ---- the spine ---- */
  .tape {
    position: relative;
    width: min(92vw, 700px);
    aspect-ratio: 188 / 25;
    display: flex;
    background: var(--bg);
    color: var(--fg);
    font-family: 'Helvetica Neue', Arial, sans-serif;
    overflow: hidden;
    isolation: isolate;
    box-shadow:
      inset 0 2px 0 rgba(255, 255, 255, 0.4),
      inset 0 -3px 7px rgba(0, 0, 0, 0.3),
      inset 0 0 0 1px rgba(0, 0, 0, 0.2),
      0 1px 0 rgba(255, 255, 255, 0.18),
      0 18px 30px -12px rgba(0, 0, 0, 0.55),
      0 6px 12px -6px rgba(0, 0, 0, 0.45);
  }

  /* convex plastic-edge sheen — subtle 3D without tilting */
  .tape::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 5;
    pointer-events: none;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.22) 0%,
      rgba(255, 255, 255, 0) 16%,
      rgba(0, 0, 0, 0) 70%,
      rgba(0, 0, 0, 0.16) 92%,
      rgba(0, 0, 0, 0.26) 100%
    );
  }

  .tape__face {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: stretch;
    width: 100%;
    height: 100%;
  }

  .tape__brand {
    display: flex;
    align-items: center;
    padding: 0 clamp(0.5rem, 1.6vw, 1.1rem);
    flex: none;
  }
  .tape__brand .bw {
    font-weight: 800;
    font-size: clamp(0.8rem, 2.4vw, 1.3rem);
    letter-spacing: 0.04em;
    color: var(--brand);
    white-space: nowrap;
    line-height: 1;
  }
  .tape__brand.is-italic .bw { font-style: italic; }
  .tape__brand.is-serif .bw { font-family: Georgia, 'Times New Roman', serif; }
  .tape__brand .box {
    background: var(--brandbox);
    color: #fff;
    padding: 0.12em 0.4em;
  }

  .tape__body {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 0.12em;
    padding: 0 0.4rem;
    min-width: 0;
    overflow: hidden;
  }
  .tape__body .pl {
    font-weight: 700;
    font-size: clamp(0.62rem, 1.7vw, 0.98rem);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    white-space: nowrap;
    line-height: 1;
  }
  .tape__body .gr {
    font-weight: 600;
    font-size: clamp(0.4rem, 1vw, 0.56rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    opacity: 0.72;
    white-space: nowrap;
    line-height: 1;
  }

  /* accents */
  .tape__rainbow {
    flex: none;
    align-self: stretch;
    display: flex;
    width: clamp(46px, 12vw, 96px);
    margin: 0 0.5rem;
  }
  .tape__rainbow span { flex: 1; }
  .tape__band {
    flex: none;
    width: clamp(4px, 0.8vw, 7px);
    align-self: stretch;
    margin: 0 0.6rem;
  }
  .tape__underline {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 2;
  }
  .tape__gradient {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 30%;
    z-index: 0;
  }

  .tape__badge {
    flex: none;
    display: flex;
    align-items: center;
    gap: clamp(0.3rem, 1vw, 0.6rem);
    padding: 0 clamp(0.5rem, 1.6vw, 1.1rem);
    border-left: 1px solid color-mix(in srgb, var(--fg) 22%, transparent);
  }
  .tape__badge .model {
    font-weight: 800;
    font-size: clamp(0.62rem, 1.7vw, 0.95rem);
    letter-spacing: 0.03em;
    white-space: nowrap;
  }
  .tape__badge .run {
    font-size: clamp(0.36rem, 0.9vw, 0.5rem);
    letter-spacing: 0.12em;
    opacity: 0.7;
    white-space: nowrap;
    text-transform: uppercase;
  }
  .vhs-logo {
    font-weight: 800;
    font-style: italic;
    font-size: clamp(0.52rem, 1.4vw, 0.78rem);
    letter-spacing: -0.04em;
    border-top: 2px solid currentColor;
    padding-top: 1px;
    line-height: 1;
  }

  /* ribbed finger-grip hint near the right end */
  .tape__grip {
    flex: none;
    width: clamp(8px, 2vw, 16px);
    background: repeating-linear-gradient(
      90deg,
      transparent 0 2px,
      rgba(0, 0, 0, 0.16) 2px 3px
    );
    opacity: 0.7;
  }

  @media (prefers-reduced-motion: reduce) {
    .vhs-stage { transition: none; }
  }
  @media (max-width: 460px) {
    .tape__body .gr { display: none; }
    .tape__grip { display: none; }
  }
</style>

<script>
  type Accent =
    | { type: 'none' }
    | { type: 'band'; colors: string[] }
    | { type: 'underline'; colors: string[]; thick?: boolean }
    | { type: 'gradient'; colors: string[] }
    | { type: 'rainbow'; colors: string[] };

  interface Tape {
    brand: string;
    italic?: boolean;
    serif?: boolean;
    brandBox?: string;
    productLine: string;
    grade: string;
    modelCode: string;
    runtime: string;
    bg: string;
    brandColor: string;
    fg: string;
    accent: Accent;
  }

  // Specs abstracted from real tapes (VHS archives + brand-color refs).
  const TAPES: Tape[] = [
    { brand: 'maxell', italic: true, productLine: 'GX-Silver', grade: 'High Quality', modelCode: 'T-120', runtime: '6 HRS · SP/EP',
      bg: '#f2f2f0', brandColor: '#005cb9', fg: '#1a1a1a', accent: { type: 'band', colors: ['#c8102e'] } },
    { brand: 'TDK', productLine: 'Super Avilyn', grade: 'Extra High Grade', modelCode: 'T-120', runtime: '6 HOURS',
      bg: '#0a1a3f', brandColor: '#ffffff', fg: '#ffffff', accent: { type: 'gradient', colors: ['#0072ce', '#00a3e0', '#36c9f0', '#7fe0f5'] } },
    { brand: 'Polaroid', productLine: 'Supercolor', grade: 'Plus', modelCode: 'T-120', runtime: '6 HRS',
      bg: '#ffffff', brandColor: '#231f20', fg: '#231f20', accent: { type: 'rainbow', colors: ['#00a3e2', '#1ba548', '#fdc800', '#f1860e', '#e41b13'] } },
    { brand: 'RCA', productLine: 'Hi-Fi Stereo', grade: 'Video Tape', modelCode: 'T-120', runtime: 'Up to 6 HRS',
      bg: '#000000', brandColor: '#e4002b', fg: '#ffffff', accent: { type: 'none' } },
    { brand: 'JVC', productLine: 'SX Gold', grade: 'High Energy', modelCode: 'T-120', runtime: '6 HRS',
      bg: '#c9a24b', brandColor: '#e60012', fg: '#1a1208', accent: { type: 'band', colors: ['#7a5a1f'] } },
    { brand: 'SONY', serif: true, productLine: 'Dynamicron', grade: 'ES · Standard Grade', modelCode: 'T-120', runtime: '6 HRS',
      bg: '#d7dade', brandColor: '#0a0a0a', fg: '#1a1a1a', accent: { type: 'band', colors: ['#c8102e'] } },
    { brand: 'FUJI', italic: true, productLine: 'Super HG', grade: 'High Grade', modelCode: 'T-120', runtime: '6 HRS',
      bg: '#ffffff', brandColor: '#e2231a', fg: '#1a1a1a', accent: { type: 'underline', colors: ['#009944'], thick: true } },
    { brand: 'BASF', brandBox: '#c50022', productLine: 'Chrome Extra', grade: 'Extra Quality', modelCode: 'T-120', runtime: '6 HRS',
      bg: '#005ca9', brandColor: '#ffffff', fg: '#ffffff', accent: { type: 'band', colors: ['#00793a'] } },
    { brand: 'Memorex', italic: true, productLine: 'Premium', grade: 'High Standard', modelCode: 'T-120', runtime: '6 HRS',
      bg: '#111111', brandColor: '#ed1c24', fg: '#ffffff', accent: { type: 'underline', colors: ['#f7941e'] } },
  ];

  const pick = <T,>(arr: T[]): T => arr[Math.floor(Math.random() * arr.length)];
  const esc = (s: string) => s.replace(/[&<>]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' }[c]!));

  function accentHTML(a: Accent): { mid: string; abs: string } {
    if (a.type === 'rainbow') {
      return { mid: `<div class="tape__rainbow">${a.colors.map((c) => `<span style="background:${c}"></span>`).join('')}</div>`, abs: '' };
    }
    if (a.type === 'band') {
      return { mid: `<div class="tape__band" style="background:${a.colors[0]}"></div>`, abs: '' };
    }
    if (a.type === 'underline') {
      return { mid: '', abs: `<div class="tape__underline" style="height:${a.thick ? 5 : 3}px;background:${a.colors[0]}"></div>` };
    }
    if (a.type === 'gradient') {
      return { mid: '', abs: `<div class="tape__gradient" style="background:linear-gradient(90deg,${a.colors.join(',')})"></div>` };
    }
    return { mid: '', abs: '' };
  }

  function buildTape(t: Tape = pick(TAPES)): HTMLElement {
    const ac = accentHTML(t.accent);
    const brandInner = t.brandBox ? `<span class="box">${esc(t.brand)}</span>` : esc(t.brand);
    const brandCls = `tape__brand${t.italic ? ' is-italic' : ''}${t.serif ? ' is-serif' : ''}`;

    const el = document.createElement('div');
    el.className = 'tape';
    el.style.cssText = `--bg:${t.bg};--fg:${t.fg};--brand:${t.brandColor};${t.brandBox ? `--brandbox:${t.brandBox};` : ''}`;
    el.innerHTML =
      `<div class="tape__face">` +
        `<div class="${brandCls}"><span class="bw">${brandInner}</span></div>` +
        ac.mid +
        `<div class="tape__body"><div class="pl">${esc(t.productLine)}</div><div class="gr">${esc(t.grade)}</div></div>` +
        `<div class="tape__grip"></div>` +
        `<div class="tape__badge"><span class="model">${esc(t.modelCode)}</span><span class="vhs-logo">VHS</span><span class="run">${esc(t.runtime)}</span></div>` +
      `</div>` +
      ac.abs;
    return el;
  }

  const stage = document.getElementById('vhs-stage');
  const inner = stage?.querySelector('.vhs-stage__inner') as HTMLElement | null;
  if (stage && inner) {
    let shown = false;
    let hideTimer: number | undefined;

    function reveal() {
      if (shown) return;
      shown = true;
      inner!.replaceChildren(buildTape());
      stage!.classList.add('reveal');
      // animate to measured content height
      stage!.style.height = inner!.offsetHeight + 'px';
      window.clearTimeout(hideTimer);
      hideTimer = window.setTimeout(() => {
        stage!.style.height = '0px';
        stage!.classList.remove('reveal');
        window.setTimeout(() => {
          inner!.replaceChildren();
          shown = false;
        }, 600);
      }, 2400);
    }

    const atTop = () => window.scrollY <= 0;

    window.addEventListener('wheel', (e) => {
      if (atTop() && e.deltaY < -4) reveal();
    }, { passive: true });

    let startY: number | null = null;
    window.addEventListener('touchstart', (e) => {
      startY = atTop() ? e.touches[0].clientY : null;
    }, { passive: true });
    window.addEventListener('touchmove', (e) => {
      if (startY !== null && e.touches[0].clientY - startY > 45) reveal();
    }, { passive: true });
    window.addEventListener('touchend', () => { startY = null; });
  }
</script>
