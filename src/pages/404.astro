---
import SiteLayout from '../layouts/SiteLayout.astro';
---

<SiteLayout
  title="404 | Page Not Found"
  description="The page you requested could not be found."
  canonical="https://zamechek.com/404.html"
>
  <main class="flex-1 container mx-auto px-4 py-16">
    <section class="max-w-xl mx-auto panel panel--striped p-8 text-center">
      <span class="panel__stripe"></span>
      <div class="prompt text-xs mb-4">$ cat ./404 &rarr; No such file or directory</div>
      <h1 class="text-3xl font-extrabold text-[var(--ink)] mb-3">404: not found</h1>
      <p class="text-[var(--muted)] mb-8">The page you requested does not exist or may have moved.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="nav-link font-bold">~/home</a>
        <a href="/blog/" class="nav-link font-bold">~/blog</a>
      </div>
    </section>
  </main>
</SiteLayout>
