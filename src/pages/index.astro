---
import SiteLayout from '../layouts/SiteLayout.astro';

const ldJson = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Shawn Zamechek",
  "url": "https://zamechek.com/",
  "email": "mailto:shawn@zamechek.com",
  "sameAs": [
    "https://www.linkedin.com/in/zamechek/",
    "https://shawnzamechek.substack.com/"
  ],
  "jobTitle": "Senior IT Director, Innovation & AI",
  "worksFor": {
    "@type": "Organization",
    "name": "The Wharton School, University of Pennsylvania"
  }
};

const extLinkSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="vertical-align:middle;"><title>External link</title><desc>Opens in a new tab</desc><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 13v6a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" /><polyline points="15 3 21 3 21 9" /><line x1="10" y1="14" x2="21" y2="3" /></svg>`;
const accountableAiBadgeUrl = 'https://api.accredible.com/v1/frontend/credential_website_embed_image/badge/129125842';
const accountableAiCertificateUrl = 'https://api.accredible.com/v1/frontend/credential_website_embed_image/certificate/129125842';
---

<SiteLayout
  title="Shawn Zamechek | AI Strategy, Innovation & Emerging Technology"
  description="Shawn Zamechek is Senior IT Director, Innovation & AI at the Wharton School, leading responsible AI adoption, governance, and emerging technology strategy."
  canonical="https://zamechek.com/"
  ldJson={ldJson}
>
  <main class="flex-1 container mx-auto px-4 py-12">
    <div class="max-w-2xl mx-auto text-center">
      <img src="/me.jpg" alt="Photo of Shawn Zamechek"
        class="w-28 h-28 object-cover mx-auto mb-6 border border-[var(--line-strong)]" />
      <div class="prompt text-xs mb-3">$ cat ./intro.txt</div>
      <h2 id="hero-title" class="text-3xl sm:text-4xl font-extrabold text-[var(--ink)] mb-4">AI Strategy, Innovation &amp; Emerging Technology</h2>
      <p class="text-base sm:text-lg text-[var(--muted)] mb-10 leading-relaxed">Driving responsible AI adoption and technology innovation at one of the world's leading business schools, from governance and experimentation to faculty partnership and university-wide strategy.</p>

      <div class="panel panel--striped text-left mb-4">
        <span class="panel__stripe"></span>
        <div class="prompt text-xs mb-2">$ history --today <span id="history-date" class="text-[var(--faint)]"></span></div>
        <div id="history-fact" class="text-sm text-[var(--ink)]"></div>
      </div>

      <!-- About Me -->
      <section id="about-me" class="mt-16 text-left scroll-mt-24">
        <div class="sec"><h3 class="sec__label">about_me</h3><hr class="sec__rule" /></div>
        <div class="panel">
          <p class="mb-3 leading-relaxed text-[var(--ink)]">I'm the Senior IT Director, Innovation &amp; AI at the Wharton School, University of Pennsylvania, where I lead Wharton Computing's approach to AI and emerging technologies in support of School priorities. My work centers on responsible AI adoption, governance, and structured experimentation that turns pilots into scalable institutional capabilities.</p>
          <p class="mb-3 leading-relaxed text-[var(--ink)]">I partner with faculty, staff, and students to ensure technology efforts are aligned and sustainable, and I represent Wharton Computing in University-wide and industry initiatives. I completed Wharton's Strategies for Accountable AI program in 2024, which deepened my focus on ethical, human-centered AI deployment.</p>
          <p class="leading-relaxed text-[var(--ink)]">Outside of work, I enjoy cooking, playing basketball, and spending time with my kids. I also serve as VP on the board of the <a href="https://www.glifecenter.org/" target="_blank" rel="noopener">Germantown Life Enrichment Center</a> in Philadelphia.</p>
        </div>
      </section>

      <!-- Work Experience -->
      <section id="work-experience" class="mt-16 text-left scroll-mt-24">
        <div class="sec"><h3 class="sec__label">work_experience</h3><hr class="sec__rule" /></div>
        <div class="space-y-5">
          <div class="panel">
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2 gap-1">
              <span class="font-bold text-[var(--ink)]">Senior IT Director, Innovation &amp; AI</span>
              <span class="text-[var(--faint)] text-sm md:ml-4">Mar 2026 – Present</span>
            </div>
            <div class="text-sm text-[var(--muted)] leading-relaxed">Lead Wharton Computing's approach to AI and emerging technologies in support of School priorities. Establish AI governance and responsible-use guardrails for ethical, scalable adoption. Design and manage structured experimentation: pilots that test, validate, and scale new technologies. Partner across faculty, staff, and students to ensure efforts are aligned and sustainable. Represent Wharton Computing in University-wide initiatives and industry partnerships.</div>
          </div>
          <div class="panel">
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2 gap-1">
              <span class="font-bold text-[var(--ink)]">Director for Research Programming &amp; Advanced Technologies</span>
              <span class="text-[var(--faint)] text-sm md:ml-4">Mar 2025 – Mar 2026</span>
            </div>
            <div class="text-sm text-[var(--muted)] leading-relaxed">Provided strategic leadership and support for advanced initiatives, especially in generative AI. Offered consulting services across the organization and school, driving innovation and technical excellence in research programming and advanced technologies.</div>
          </div>
          <div class="panel">
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2 gap-1">
              <span class="font-bold text-[var(--ink)]">IT Director of Research Programming</span>
              <span class="text-[var(--faint)] text-sm md:ml-4">Aug 2021 – Mar 2025</span>
            </div>
            <div class="text-sm text-[var(--muted)] leading-relaxed">Led and mentored a team of research developers and data engineers, delivered innovative solutions for Wharton faculty. Served as technical manager for AI and LLM projects, including the CARGO lecture recall application and LLM-powered research tools. Consulted for large-scale studies and research initiatives.</div>
          </div>
          <div class="panel">
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2 gap-1">
              <span class="font-bold text-[var(--ink)]">Senior IT Project Leader</span>
              <span class="text-[var(--faint)] text-sm md:ml-4">Oct 2017 – Aug 2021</span>
            </div>
            <div class="text-sm text-[var(--muted)] leading-relaxed">Designed and implemented project management and reporting tools. Promoted services through blogs and web presence. Built and maintained large social media and Amazon review datasets. Led cloud migration strategy for school-wide infrastructure.</div>
          </div>
          <div class="panel">
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2 gap-1">
              <span class="font-bold text-[var(--ink)]">Senior Research Programmer</span>
              <span class="text-[var(--faint)] text-sm md:ml-4">Jul 2015 – Oct 2017</span>
            </div>
            <div class="text-sm text-[var(--muted)] leading-relaxed">Developed applications for advanced research, including modeling simulations. Mentored junior developers. Evaluated and recommended technology stacks and scientific libraries. Released open-source corpus classification library.</div>
          </div>
          <div class="panel">
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2 gap-1">
              <span class="font-bold text-[var(--ink)]">Junior Research Programmer</span>
              <span class="text-[var(--faint)] text-sm md:ml-4">Apr 2013 – Jul 2015</span>
            </div>
            <div class="text-sm text-[var(--muted)] leading-relaxed">Built specialized research applications, including a photography simulation tool. Migrated Google n-gram corpus to AWS S3 for efficient querying. Conducted topic modeling on large news corpora for election analysis.</div>
          </div>
        </div>
      </section>

      <!-- Education -->
      <section id="education" class="mt-16 text-left scroll-mt-24">
        <div class="sec"><h3 class="sec__label">education</h3><hr class="sec__rule" /></div>
        <div class="space-y-5">
          <div class="panel">
            <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2 gap-1">
              <span class="font-bold text-[var(--ink)]">University of Pennsylvania | Wharton Executive Education</span>
              <span class="text-[var(--faint)] text-sm md:ml-4">2024</span>
            </div>
            <div class="font-medium text-[var(--accent)] mb-1">Certificate: Strategies for Accountable AI</div>
            <div class="text-sm text-[var(--muted)] leading-relaxed">Comprehensive roadmap for responsible, safe, and ethical AI implementation, covering accuracy, risk, transparency, fairness, bias, privacy, and legal compliance. Led by Wharton AI &amp; Analytics Initiative faculty.</div>
            <div class="mt-4 flex flex-col sm:flex-row sm:items-center gap-3">
              <a href={accountableAiCertificateUrl} target="_blank" rel="noopener noreferrer" aria-label="View full certificate image for Strategies for Accountable AI">
