---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  ogType?: string;
  ldJson?: object;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://zamechek.com/me.jpg',
  ogType = 'website',
  ldJson,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <script is:inline>if(!['zamechek.com','localhost','127.0.0.1'].includes(location.hostname))location.replace('https://zamechek.com'+location.pathname+location.search);</script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index,follow,max-image-preview:large" />
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/jpeg" href="/me.jpg" />
  <link rel="alternate" type="application/rss+xml" title="Shawn Zamechek Blog RSS" href="https://zamechek.com/blog/rss.xml" />
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <!-- Google tag (gtag.js) -->
  <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-K2VQENWRZJ"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-K2VQENWRZJ');
  </script>
  {ldJson && <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;1,8..60,400&display=swap" rel="stylesheet" />
</head>
<body class="bg-gradient-to-br from-green-100 via-gray-50 to-green-50 min-h-screen flex flex-col">
  <slot />
  <script>
    // Cursor-warped baseline + reflow-as-animation on headings + emphasized labels
    (function warpAll() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const selector = 'h1, h2, h3, h4, h5, h6, .font-semibold.text-lg, .font-semibold.text-md';
      const elements = Array.from(document.querySelectorAll<HTMLElement>(selector));
      type Target = { el: HTMLElement; glyphs: HTMLSpanElement[] };
      const targets: Target[] = [];
      for (const el of elements) {
        const glyphs: HTMLSpanElement[] = [];
        const newChildren: Node[] = [];
        for (const node of Array.from(el.childNodes)) {
          if (node.nodeType === Node.TEXT_NODE) {
            const parts = (node.textContent || '').split(/(\s+)/);
            for (const part of parts) {
              if (!part) continue;
              if (/^\s+$/.test(part)) { newChildren.push(document.createTextNode(part)); continue; }
              const wrap = document.createElement('span');
              wrap.style.display = 'inline-block';
              wrap.style.whiteSpace = 'nowrap';
              for (const ch of part) {
                const s = document.createElement('span');
                s.textContent = ch;
                s.style.display = 'inline-block';
                s.style.willChange = 'transform';
                wrap.appendChild(s);
                glyphs.push(s);
              }
              newChildren.push(wrap);
            }
          } else {
            newChildren.push(node);
          }
        }
        el.replaceChildren(...newChildren);
        targets.push({ el, glyphs });
      }
      const sigma = 90, maxAmp = 2.6, yRange = 160, gain = 0.065;
      const flipDuration = 500;
      const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
      let cx = -9999, cy = -9999;
      window.addEventListener('mousemove', (e) => { cx = e.clientX; cy = e.clientY; });
      type Center = { x: number; y: number };
      type Flip = { startX: number; startY: number; t0: number };
      const centerMap = new WeakMap<Target, Center[]>();
      const flipMap = new WeakMap<Target, Flip[]>();
      const computeWarp = (c: Center) => {
        const dy = cy - c.y;
        const yFalloff = Math.max(0, 1 - Math.abs(dy) / yRange);
        if (yFalloff <= 0) return 0;
        const dx = cx - c.x;
        const xFalloff = Math.exp(-(dx * dx) / (2 * sigma * sigma));
        return Math.sign(dy) * Math.min(Math.abs(dy) * gain, maxAmp) * xFalloff * yFalloff;
      };
      const computeFlip = (f: Flip, now: number) => {
        const progress = Math.min(1, Math.max(0, (now - f.t0) / flipDuration));
        const k = 1 - easeOut(progress);
        return { x: f.startX * k, y: f.startY * k };
      };
      const applyTransforms = () => {
        const now = performance.now();
        for (const t of targets) {
          const centers = centerMap.get(t)!;
          const flips = flipMap.get(t)!;
          for (let i = 0; i < t.glyphs.length; i++) {
            const fp = computeFlip(flips[i], now);
            const wy = computeWarp(centers[i]);
            t.glyphs[i].style.transform = `translate(${fp.x.toFixed(2)}px, ${(fp.y + wy).toFixed(2)}px)`;
          }
        }
      };
      const measureLayout = (animate: boolean) => {
        const now = performance.now();
        if (animate) {
          for (const t of targets) for (const g of t.glyphs) g.style.transform = '';
        }
        for (const t of targets) {
          const newCenters: Center[] = t.glyphs.map(g => {
            const r = g.getBoundingClientRect();
            return { x: r.left + r.width / 2, y: r.top + r.height / 2 };
          });
          const oldCenters = centerMap.get(t);
          const oldFlips = flipMap.get(t);
          if (animate && oldCenters && oldFlips && oldCenters.length === newCenters.length) {
            const newFlips: Flip[] = t.glyphs.map((_, i) => {
              const cur = computeFlip(oldFlips[i], now);
              const oldWarp = computeWarp(oldCenters[i]);
              const newWarp = computeWarp(newCenters[i]);
              return {
                startX: oldCenters[i].x + cur.x - newCenters[i].x,
                startY: oldCenters[i].y + cur.y + oldWarp - newCenters[i].y - newWarp,
                t0: now,
              };
            });
            flipMap.set(t, newFlips);
          } else {
            flipMap.set(t, t.glyphs.map(() => ({ startX: 0, startY: 0, t0: -1e9 })));
          }
          centerMap.set(t, newCenters);
        }
        if (animate) applyTransforms();
      };
      measureLayout(false);
      if (document.fonts && document.fonts.ready) document.fonts.ready.then(() => measureLayout(true));
      let resizeRAF = 0;
      window.addEventListener('resize', () => {
        if (resizeRAF) return;
        resizeRAF = requestAnimationFrame(() => { resizeRAF = 0; measureLayout(true); });
      });
      function tick() { applyTransforms(); requestAnimationFrame(tick); }
      requestAnimationFrame(tick);
    })();
  </script>
</body>
</html>
