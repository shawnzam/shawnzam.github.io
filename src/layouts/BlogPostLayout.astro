---
import SiteLayout from './SiteLayout.astro';

interface Props {
  title: string;
  description: string;
  canonical: string;
  ogImage?: string;
  publishedDate?: Date;
  type?: string;
  ldJson?: object;
}

const { title, description, canonical, ogImage, publishedDate, type, ldJson } = Astro.props;

const formattedDate = publishedDate
  ? publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
  : '';
---

<SiteLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
  ldJson={ldJson}
>
  <main class="flex-1 container mx-auto px-4 py-12">
    <article class="max-w-3xl mx-auto">
      <div class="prompt text-xs mb-4"><a href="/blog/" class="nav-link">cd ..</a></div>
      {ogImage && (
        <img
          src={ogImage.replace('https://zamechek.com', '')}
          alt={`Title image for ${title}`}
          class="w-full h-64 sm:h-80 object-cover border border-[var(--line-strong)] mb-8"
        />
      )}
      <div class="panel panel--striped p-6 sm:p-10">
        <span class="panel__stripe"></span>
        <header class="mb-8">
          <div class="flex items-center gap-3 mb-3">
            {type && <span class="text-xs font-bold tracking-widest text-[var(--accent)] uppercase">{type}</span>}
            {formattedDate && <span class="text-xs text-[var(--faint)]">· {formattedDate}</span>}
          </div>
          <h1 class="text-2xl sm:text-3xl font-extrabold text-[var(--ink)]">{title}</h1>
        </header>
        <div class="post-content max-w-none">
          <slot />
        </div>
        <div class="mt-12 pt-6 border-t border-[var(--line)]">
          <a href="/blog/" class="font-bold">&larr; back to blog</a>
        </div>
      </div>
    </article>
  </main>
</SiteLayout>

<style is:global>
  .post-content {
    color: var(--ink);
    font-size: 0.95rem;
  }

  .post-content h1,
  .post-content h2,
  .post-content h3,
  .post-content h4 {
    font-weight: 700;
    margin-top: 2.25rem;
    margin-bottom: 0.75rem;
    color: var(--ink);
    line-height: 1.3;
  }

  .post-content h1 { font-size: 1.5rem; }
  .post-content h2 { font-size: 1.25rem; }
  .post-content h3 { font-size: 1.1rem; }
  .post-content h4 { font-size: 1rem; }

  .post-content h2::before,
  .post-content h3::before {
    content: '## ';
    color: var(--accent);
    font-weight: 400;
  }
  .post-content h3::before { content: '### '; }

  .post-content p {
    margin-bottom: 1.25rem;
    line-height: 1.85;
    color: var(--ink);
  }

  .post-content li {
    margin-bottom: 0.4rem;
    line-height: 1.75;
    color: var(--ink);
  }

  .post-content ul {
    list-style: none;
    padding-left: 1.4rem;
    margin-bottom: 1.25rem;
  }
  .post-content ul > li::marker { content: ''; }
  .post-content ul > li {
    position: relative;
  }
  .post-content ul > li::before {
    content: '-';
    position: absolute;
    left: -1.4rem;
    color: var(--accent);
  }

  .post-content ol {
    list-style: decimal;
    padding-left: 1.6rem;
    margin-bottom: 1.25rem;
  }
  .post-content ol > li::marker {
    color: var(--accent);
  }

  .post-content a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
  }
  .post-content a:hover {
    color: var(--accent-ink);
  }

  .post-content hr {
    border: none;
    border-top: 1px dashed var(--line-strong);
    margin: 2rem 0;
  }

  .post-content blockquote {
    border-left: 2px solid var(--accent);
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: var(--muted);
  }

  .post-content code {
    background: var(--surface-2);
    border: 1px solid var(--line);
    padding: 0.1em 0.35em;
    font-size: 0.85em;
    color: var(--accent-ink);
  }

  .post-content pre {
    background: var(--surface-2);
    color: var(--ink);
    padding: 1rem 1.1rem;
    border: 1px solid var(--line-strong);
    overflow-x: auto;
    margin-bottom: 1.25rem;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .post-content pre code {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }

  .post-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    overflow-x: auto;
    display: block;
  }

  .post-content th {
    background: var(--surface-2);
    color: var(--ink);
    font-weight: 700;
    text-align: left;
    padding: 0.5rem 0.8rem;
    border: 1px solid var(--line-strong);
    white-space: nowrap;
  }

  .post-content td {
    padding: 0.5rem 0.8rem;
    border: 1px solid var(--line);
    color: var(--ink);
    vertical-align: top;
  }

  .post-content img {
    border: 1px solid var(--line-strong);
    margin: 1.5rem 0;
  }
</style>
