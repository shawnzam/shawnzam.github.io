---
import SocialLinks from './SocialLinks.astro';
---

<footer class="bg-white border-t py-4 mt-auto">
  <div class="container mx-auto px-4 text-center text-gray-500">
    <div class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1 text-sm">
      <span>&copy; <span id="footer-year"></span> <a href="mailto:shawn@zamechek.com" class="hover:underline">Shawn Zamechek</a>.</span>
      <SocialLinks />
    </div>
  </div>
</footer>

<script>
  const el = document.getElementById('footer-year');
  if (el) el.textContent = String(new Date().getFullYear());
</script>
